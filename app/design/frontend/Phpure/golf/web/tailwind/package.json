{
  "name": "@phpure/golf-theme",
  "version": "1.0.0",
  "description": "Phpure Golf Hyvä child theme - Tailwind CSS build",
  "type": "module",
  "private": true,
  "dependencies": {
    "@hyva-themes/hyva-modules": "^1.3.0",
    "@tailwindcss/cli": "^4.1.17",
    "tailwindcss": "^4.1.17"
  },
  "scripts": {
    "start": "npm run watch",
    "generate": "npx hyva-sources && npx hyva-tokens",
    "prewatch": "npm run generate",
    "watch": "npx tailwindcss -i tailwind-source.css -o ../css/styles.css --watch",
    "prebuild": "npm run generate",
    "build": "npx tailwindcss -i tailwind-source.css -o ../css/styles.css --minify"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "browserslist": [
    "> 0.5% and not dead"
  ]
}
